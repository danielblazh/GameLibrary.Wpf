<Window x:Class="GameLibrary.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GameLibrary.Wpf.Views"
        xmlns:vm="clr-namespace:GameLibrary.Wpf.ViewModels"
        xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
        Title="&#x1F3AE; Game Library" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- DataTemplate mapping: ViewModel to View -->
        <DataTemplate DataType="{x:Type vm:MainPageViewModel}">
            <views:MainPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:Dashboard/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameLibraryViewModel}">
            <views:GameLibraryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameProfileViewModel}">
            <views:GameProfileView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminViewModel}">
            <views:AdminDashboard/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AchievementsViewModel}">
            <views:AchievementsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LeaderboardViewModel}">
            <views:LeaderboardView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBg}" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#x1F3AE; Game Library"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentUsername, Mode=OneWay}"
                           Foreground="White" FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}"/>
                <Button Grid.Column="2"
                        Content="{Binding ThemeIcon, Mode=OneWay}"
                        Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource ThemeToggleButton}"/>
                <Button Grid.Column="3"
                        Content="&#x1F6AA; &#x05D9;&#x05E6;&#x05D9;&#x05D0;&#x05D4;"
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource ThemeToggleButton}"
                        FontSize="14"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource FooterBg}" Padding="16,4">
            <TextBlock Text="Game Library v1.0 | 2025"
                       Foreground="{DynamicResource SecondaryText}"
                       HorizontalAlignment="Center" FontSize="12"/>
        </Border>

        <!-- Sidebar (visible when logged in) -->
        <Border DockPanel.Dock="Left" Width="200"
                Background="{DynamicResource SidebarBg}"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="8">
                <TextBlock Text="&#x05EA;&#x05E4;&#x05E8;&#x05D9;&#x05D8;"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="12" Margin="8,8,8,4"/>
                <Button Content="&#x1F3E0; &#x05D3;&#x05E3; &#x05E8;&#x05D0;&#x05E9;&#x05D9;"
                        Command="{Binding NavigateToDashboardCommand}"
                        Style="{StaticResource SidebarButton}"/>
                <Button Content="&#x1F3AE; &#x05E1;&#x05E4;&#x05E8;&#x05D9;&#x05D9;&#x05D4;"
                        Command="{Binding NavigateToLibraryCommand}"
                        Style="{StaticResource SidebarButton}"/>
                <Button Content="&#x1F4CA; &#x05E1;&#x05D8;&#x05D8;&#x05D9;&#x05E1;&#x05D8;&#x05D9;&#x05E7;&#x05D5;&#x05EA;"
                        Command="{Binding NavigateToStatsCommand}"
                        Style="{StaticResource SidebarButton}"/>
                <Button Content="&#x1F3C6; &#x05DC;&#x05D5;&#x05D7; &#x05EA;&#x05D5;&#x05E6;&#x05D0;&#x05D5;&#x05EA;"
                        Command="{Binding NavigateToLeaderboardCommand}"
                        Style="{StaticResource SidebarButton}"/>
                <Button Content="&#x1F6E0;&#xFE0F; &#x05E0;&#x05D9;&#x05D4;&#x05D5;&#x05DC;"
                        Command="{Binding NavigateToAdminCommand}"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ContentControl Content="{Binding Navigation.CurrentView}" Margin="0"/>

    </DockPanel>
</Window>
