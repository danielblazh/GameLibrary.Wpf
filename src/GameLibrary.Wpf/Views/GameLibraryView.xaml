<UserControl x:Class="GameLibrary.Wpf.Views.GameLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <UserControl.Resources>
        <converters:RatingToStarsConverter x:Key="RatingToStars"/>
        <converters:StatusToIconConverter x:Key="StatusToIcon"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:HoursToTextConverter x:Key="HoursToText"/>
        <converters:LevelToTextConverter x:Key="LevelToText"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="{Binding [Back], Source={x:Static services:TranslationSource.Instance}}"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding [GameLibraryTitle], Source={x:Static services:TranslationSource.Instance}}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Search & Filter Bar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource StyledTextBox}"
                     Margin="0,0,8,0"/>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Statuses, Mode=OneTime}"
                      SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                      Style="{StaticResource StyledComboBox}"
                      MinWidth="120" Margin="0,0,8,0"/>

            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre, Mode=TwoWay}"
                      Style="{StaticResource StyledComboBox}"
                      MinWidth="120" Margin="0,0,8,0"/>

            <Button Grid.Column="3"
                    Content="{Binding [AddGame], Source={x:Static services:TranslationSource.Instance}}"
                    Command="{Binding AddGameCommand}"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- Games DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Games}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="{DynamicResource CardBackground}"
                  Foreground="{DynamicResource PrimaryText}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False"
                  RowBackground="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource GridRowAlt}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding [Status], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                    Width="60"/>
                <DataGridTextColumn Header="{Binding [GameName], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="{Binding [Genre], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Genre}" Width="120"/>
                <DataGridTextColumn Header="{Binding [Platform], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Platform}" Width="120"/>
                <DataGridTextColumn Header="{Binding [Rating], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Rating, Converter={StaticResource RatingToStars}}"
                                    Width="120"/>
                <DataGridTextColumn Header="{Binding [Hours], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding HoursPlayed, Converter={StaticResource HoursToText}}"
                                    Width="100"/>
                <DataGridTextColumn Header="{Binding [Level], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Level, Converter={StaticResource LevelToText}}"
                                    Width="80"/>
                <DataGridTemplateColumn Header="{Binding [Actions], Source={x:Static services:TranslationSource.Instance}}" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="&#x270F;&#xFE0F;"
                                        Command="{Binding DataContext.EditGameCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4" Margin="0,0,4,0" FontSize="12"/>
                                <Button Content="&#x1F3C6;"
                                        Command="{Binding DataContext.AchievementsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4" Margin="0,0,4,0" FontSize="12"/>
                                <Button Content="&#x1F5D1;&#xFE0F;"
                                        Command="{Binding DataContext.DeleteGameCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButton}"
                                        Padding="8,4" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Text="{Binding GamesFoundText, Mode=OneWay}"
                   Foreground="{DynamicResource SecondaryText}"
                   Margin="0,8,0,0" FontSize="12"/>
    </Grid>
</UserControl>
