<UserControl x:Class="GameLibrary.Wpf.Views.LeaderboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <Grid Background="{DynamicResource AppBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="{Binding [Back], Source={x:Static services:TranslationSource.Instance}}"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding [LeaderboardTitle], Source={x:Static services:TranslationSource.Instance}}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Leaderboard Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="{DynamicResource CardBackground}"
                  Foreground="{DynamicResource PrimaryText}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False"
                  RowBackground="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource GridRowAlt}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding [Rank], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Rank}" Width="60"/>
                <DataGridTextColumn Header="{Binding [Username], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="{Binding [HoursPlayed], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding TotalHours, StringFormat={}{0:F1}}" Width="120"/>
                <DataGridTextColumn Header="{Binding [CompletedGames], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding CompletedGames}" Width="100"/>
                <DataGridTextColumn Header="{Binding [TotalGames], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding TotalGames}" Width="120"/>
                <DataGridTextColumn Header="{Binding [AverageRating], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding AverageRating, StringFormat={}{0:F1}}" Width="120"/>
                <DataGridTextColumn Header="{Binding [Achievements], Source={x:Static services:TranslationSource.Instance}}"
                                    Binding="{Binding UnlockedAchievements}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
