<UserControl x:Class="GameLibrary.Wpf.Views.LeaderboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{DynamicResource AppBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="&#x2190; &#x05D7;&#x05D6;&#x05E8;&#x05D4;"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>
            <TextBlock Text="&#x1F3C6; &#x05DC;&#x05D5;&#x05D7; &#x05EA;&#x05D5;&#x05E6;&#x05D0;&#x05D5;&#x05EA;"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Leaderboard Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="{DynamicResource CardBackground}"
                  Foreground="{DynamicResource PrimaryText}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False"
                  RowBackground="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource GridRowAlt}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="&#x05DE;&#x05E7;&#x05D5;&#x05DD;"
                                    Binding="{Binding Rank}" Width="60"/>
                <DataGridTextColumn Header="&#x05E9;&#x05DD; &#x05DE;&#x05E9;&#x05EA;&#x05DE;&#x05E9;"
                                    Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="&#x05E9;&#x05E2;&#x05D5;&#x05EA; &#x05DE;&#x05E9;&#x05D7;&#x05E7;"
                                    Binding="{Binding TotalHours, StringFormat={}{0:F1}}" Width="120"/>
                <DataGridTextColumn Header="&#x05D4;&#x05D5;&#x05E9;&#x05DC;&#x05DE;&#x05D5;"
                                    Binding="{Binding CompletedGames}" Width="100"/>
                <DataGridTextColumn Header="&#x05E1;&#x05D4;&quot;&#x05DB; &#x05DE;&#x05E9;&#x05D7;&#x05E7;&#x05D9;&#x05DD;"
                                    Binding="{Binding TotalGames}" Width="120"/>
                <DataGridTextColumn Header="&#x05D3;&#x05D9;&#x05E8;&#x05D5;&#x05D2; &#x05DE;&#x05DE;&#x05D5;&#x05E6;&#x05E2;"
                                    Binding="{Binding AverageRating, StringFormat={}{0:F1}}" Width="120"/>
                <DataGridTextColumn Header="&#x1F3C6; &#x05D4;&#x05D9;&#x05E9;&#x05D2;&#x05D9;&#x05DD;"
                                    Binding="{Binding UnlockedAchievements}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
