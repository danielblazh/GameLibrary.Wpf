<UserControl x:Class="GameLibrary.Wpf.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <StackPanel Margin="32">
            <!-- Welcome -->
            <TextBlock Text="{Binding WelcomeMessage, Mode=OneWay}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       Margin="0,0,0,24"/>

            <!-- Stats Cards -->
            <WrapPanel Margin="0,0,0,32">
                <!-- Total Games -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="{Binding [TotalGames], Source={x:Static services:TranslationSource.Instance}}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding TotalGames, Mode=OneWay}"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Playing Now -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="{Binding [PlayingNow], Source={x:Static services:TranslationSource.Instance}}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding PlayingCount, Mode=OneWay}"
                                   Foreground="#00B894" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Completed -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="{Binding [CompletedGames], Source={x:Static services:TranslationSource.Instance}}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding CompletedCount, Mode=OneWay}"
                                   Foreground="#0984E3" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Hours -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="{Binding [HoursPlayed], Source={x:Static services:TranslationSource.Instance}}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding TotalHours, Mode=OneWay, StringFormat={}{0:F1}}"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Navigation Buttons -->
            <TextBlock Text="{Binding [QuickNav], Source={x:Static services:TranslationSource.Instance}}"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,16"/>

            <WrapPanel>
                <Button Content="{Binding [SidebarLibrary], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding GameLibraryCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,16,8" FontSize="16"/>

                <Button Content="{Binding [SidebarStats], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding StatisticsCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,16,8" FontSize="16"/>

                <Button Content="{Binding [SidebarLeaderboard], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding LeaderboardCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,16,8" FontSize="16"/>

                <Button Content="{Binding [SidebarAdmin], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding AdminCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,16,8" FontSize="16"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>
