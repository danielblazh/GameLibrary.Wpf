<UserControl x:Class="GameLibrary.Wpf.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <StackPanel Margin="32">
            <!-- Welcome -->
            <TextBlock Text="{Binding WelcomeMessage, Mode=OneWay}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}"
                       Margin="0,0,0,24"/>

            <!-- Stats Cards -->
            <WrapPanel Margin="0,0,0,32">
                <!-- Total Games -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="&#x1F3AE; &#x05E1;&#x05D4;&quot;&#x05DB; &#x05DE;&#x05E9;&#x05D7;&#x05E7;&#x05D9;&#x05DD;"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding TotalGames, Mode=OneWay}"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Playing Now -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="&#x25B6;&#xFE0F; &#x05DE;&#x05E9;&#x05D7;&#x05E7; &#x05E2;&#x05DB;&#x05E9;&#x05D9;&#x05D5;"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding PlayingCount, Mode=OneWay}"
                                   Foreground="#00B894" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Completed -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="&#x2705; &#x05D4;&#x05D5;&#x05E9;&#x05DC;&#x05DE;&#x05D5;"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding CompletedCount, Mode=OneWay}"
                                   Foreground="#0984E3" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Total Hours -->
                <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,16" MinWidth="200">
                    <StackPanel>
                        <TextBlock Text="&#x23F1;&#xFE0F; &#x05E9;&#x05E2;&#x05D5;&#x05EA; &#x05DE;&#x05E9;&#x05D7;&#x05E7;"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                        <TextBlock Text="{Binding TotalHours, Mode=OneWay, StringFormat={}{0:F1}}"
                                   Foreground="{DynamicResource PrimaryText}" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Navigation Buttons -->
            <TextBlock Text="&#x05E0;&#x05D9;&#x05D5;&#x05D5;&#x05D8; &#x05DE;&#x05D4;&#x05D9;&#x05E8;"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,16"/>

            <WrapPanel>
                <Button Content="&#x1F3AE; &#x05E1;&#x05E4;&#x05E8;&#x05D9;&#x05D9;&#x05EA; &#x05DE;&#x05E9;&#x05D7;&#x05E7;&#x05D9;&#x05DD;"
                        Command="{Binding GameLibraryCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,16,8" FontSize="16"/>

                <Button Content="&#x1F4CA; &#x05E1;&#x05D8;&#x05D8;&#x05D9;&#x05E1;&#x05D8;&#x05D9;&#x05E7;&#x05D5;&#x05EA;"
                        Command="{Binding StatisticsCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,16,8" FontSize="16"/>

                <Button Content="&#x1F6E0;&#xFE0F; &#x05E0;&#x05D9;&#x05D4;&#x05D5;&#x05DC; &#x05DE;&#x05E9;&#x05EA;&#x05DE;&#x05E9;&#x05D9;&#x05DD;"
                        Command="{Binding AdminCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,16,8" FontSize="16"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>
