<UserControl x:Class="GameLibrary.Wpf.Views.AdminDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="&#x2190; &#x05D7;&#x05D6;&#x05E8;&#x05D4;"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>
            <TextBlock Text="&#x1F6E0;&#xFE0F; &#x05E0;&#x05D9;&#x05D4;&#x05D5;&#x05DC; &#x05DE;&#x05E9;&#x05EA;&#x05DE;&#x05E9;&#x05D9;&#x05DD;"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Search & Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource StyledTextBox}" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Roles, Mode=OneTime}"
                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                      Style="{StaticResource StyledComboBox}" MinWidth="120"/>
        </Grid>

        <!-- Add/Edit User Form -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackground}"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle, Mode=OneWay}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding FormUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextBox}"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding FormEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextBox}"/>
                    <ComboBox Grid.Column="4"
                              SelectedItem="{Binding FormRole, Mode=TwoWay}"
                              Style="{StaticResource StyledComboBox}">
                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Admin</sys:String>
                        <sys:String>User</sys:String>
                        <sys:String>Guest</sys:String>
                    </ComboBox>
                    <Button Grid.Column="6"
                            Content="&#x05E9;&#x05DE;&#x05D5;&#x05E8;"
                            Command="{Binding SaveUserCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                    <Button Grid.Column="8"
                            Content="&#x05D1;&#x05D9;&#x05D8;&#x05D5;&#x05DC;"
                            Command="{Binding CancelEditCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </Grid>
                <!-- Password (only for new users) -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                            Visibility="{Binding IsEditingUser, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <TextBlock Text="&#x05E1;&#x05D9;&#x05E1;&#x05DE;&#x05D4;:" Foreground="{DynamicResource PrimaryText}"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <PasswordBox x:Name="FormPasswordBox"
                                 Style="{StaticResource StyledPasswordBox}"
                                 Width="200"
                                 PasswordChanged="FormPasswordBox_PasswordChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Users Table -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Users}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Background="{DynamicResource CardBackground}"
                  Foreground="{DynamicResource PrimaryText}"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeRows="False"
                  RowBackground="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource GridRowAlt}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="&#x05E9;&#x05DD; &#x05DE;&#x05E9;&#x05EA;&#x05DE;&#x05E9;" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="&#x05D0;&#x05D9;&#x05DE;&#x05D9;&#x05D9;&#x05DC;" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="&#x05EA;&#x05E4;&#x05E7;&#x05D9;&#x05D3;" Binding="{Binding Role}" Width="100"/>
                <DataGridTextColumn Header="&#x05EA;&#x05D0;&#x05E8;&#x05D9;&#x05DA; &#x05D4;&#x05E6;&#x05D8;&#x05E8;&#x05E4;&#x05D5;&#x05EA;"
                                    Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                <DataGridTemplateColumn Header="&#x05E4;&#x05E2;&#x05D5;&#x05DC;&#x05D5;&#x05EA;" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="&#x270F;&#xFE0F;"
                                        Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,4" Margin="0,0,4,0" FontSize="12"/>
                                <Button Content="&#x1F5D1;&#xFE0F;"
                                        Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButton}"
                                        Padding="8,4" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
