<UserControl x:Class="GameLibrary.Wpf.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <Grid Background="{DynamicResource AppBackground}" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <Button Content="{Binding [Back], Source={x:Static services:TranslationSource.Instance}}"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding [StatisticsTitle], Source={x:Static services:TranslationSource.Instance}}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Summary Cards -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,24">
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,8" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="{Binding [TotalGamesLabel], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                    <TextBlock Text="{Binding TotalGames, Mode=OneWay}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,8" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="{Binding [TotalHoursLabel], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                    <TextBlock Text="{Binding TotalHours, Mode=OneWay, StringFormat={}{0:F1}}" FontSize="32" FontWeight="Bold" Foreground="#0984E3"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,8" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="{Binding [AverageRating], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                    <TextBlock Text="{Binding AverageRating, Mode=OneWay, StringFormat={}{0:F1}/10}" FontSize="32" FontWeight="Bold" Foreground="#FDCB6E"/>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24" Margin="0,0,16,8" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="{Binding [Achievements], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource SecondaryText}" FontSize="14"/>
                    <TextBlock Foreground="#00B894" FontSize="32" FontWeight="Bold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                                <Binding Path="UnlockedAchievements" Mode="OneWay"/>
                                <Binding Path="TotalAchievements" Mode="OneWay"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Details -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- By Status -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24">
                <StackPanel>
                    <TextBlock Text="{Binding [ByStatus], Source={x:Static services:TranslationSource.Instance}}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding StatusStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="{DynamicResource PrimaryText}" FontSize="14"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Percentage, Mode=OneWay}"
                                                 Maximum="100" Height="16" Margin="8,0"
                                                 Foreground="#0984E3" Background="{DynamicResource InputBg}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}"
                                               Foreground="{DynamicResource SecondaryText}" FontSize="14"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- By Genre -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="24">
                <StackPanel>
                    <TextBlock Text="{Binding [ByGenre], Source={x:Static services:TranslationSource.Instance}}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding GenreStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="{DynamicResource PrimaryText}" FontSize="14"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Percentage, Mode=OneWay}"
                                                 Maximum="100" Height="16" Margin="8,0"
                                                 Foreground="#00B894" Background="{DynamicResource InputBg}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}"
                                               Foreground="{DynamicResource SecondaryText}" FontSize="14"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
