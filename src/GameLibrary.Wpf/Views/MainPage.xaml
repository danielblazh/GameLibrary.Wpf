<UserControl x:Class="GameLibrary.Wpf.Views.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <Grid Background="{DynamicResource AppBackground}">
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="400">
            <StackPanel HorizontalAlignment="Center">
                <!-- Logo -->
                <TextBlock Text="&#x1F3AE;"
                           FontSize="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{Binding [AppTitle], Source={x:Static services:TranslationSource.Instance}}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding [MainPageSubtitle], Source={x:Static services:TranslationSource.Instance}}"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Buttons -->
                <Button Content="{Binding [Login], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="240"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16"
                        FontSize="16"/>

                <Button Content="{Binding [Register], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding RegisterCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Width="240"
                        HorizontalAlignment="Center"
                        FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
