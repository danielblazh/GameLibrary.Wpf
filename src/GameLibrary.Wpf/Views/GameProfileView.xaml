<UserControl x:Class="GameLibrary.Wpf.Views.GameProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="32"
                Margin="32"
                MaxWidth="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding PageTitle, Mode=OneWay}"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}"
                           Margin="0,0,0,24"/>

                <!-- Title -->
                <TextBlock Text="{Binding [GameName], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource StyledTextBox}"/>
                <TextBlock Text="{Binding TitleError, Mode=OneWay}" Style="{StaticResource ErrorText}" Margin="0,0,0,8"/>

                <!-- Genre & Platform -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding [Genre], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding GenreOptions, Mode=OneTime}"
                                  SelectedItem="{Binding Genre, Mode=TwoWay}"
                                  Style="{StaticResource StyledComboBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding [Platform], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding PlatformOptions, Mode=OneTime}"
                                  SelectedItem="{Binding Platform, Mode=TwoWay}"
                                  Style="{StaticResource StyledComboBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Status & Rating -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding [Status], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding StatusOptions, Mode=OneTime}"
                                  SelectedItem="{Binding Status, Mode=TwoWay}"
                                  Style="{StaticResource StyledComboBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding [RatingLabel], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding RatingOptions, Mode=OneTime}"
                                  SelectedItem="{Binding Rating, Mode=TwoWay}"
                                  Style="{StaticResource StyledComboBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Level -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding [LevelLabel], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding LevelOptions, Mode=OneTime}"
                                  SelectedItem="{Binding Level, Mode=TwoWay}"
                                  Style="{StaticResource StyledComboBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Hours & Release Date -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding [HoursPlayedLabel], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding HoursPlayed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource StyledTextBox}"/>
                        <TextBlock Text="{Binding HoursError, Mode=OneWay}" Style="{StaticResource ErrorText}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding [ReleaseDate], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding ReleaseDate, Mode=TwoWay}"
                                    Background="{DynamicResource InputBg}"
                                    Foreground="{DynamicResource InputText}"
                                    BorderBrush="{DynamicResource InputBorder}"/>
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <TextBlock Text="{Binding [Notes], Source={x:Static services:TranslationSource.Instance}}" Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Notes, Mode=TwoWay}"
                         Style="{StaticResource StyledTextBox}"
                         AcceptsReturn="True" MinLines="3"
                         Margin="0,0,0,16"/>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Style="{StaticResource ErrorText}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,0,0,8"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="{Binding [Save], Source={x:Static services:TranslationSource.Instance}}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,16,0" FontSize="16"/>
                    <Button Content="{Binding [Cancel], Source={x:Static services:TranslationSource.Instance}}"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="16"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
