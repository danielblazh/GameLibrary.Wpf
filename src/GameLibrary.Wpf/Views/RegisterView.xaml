<UserControl x:Class="GameLibrary.Wpf.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GameLibrary.Wpf.Converters"
             xmlns:services="clr-namespace:GameLibrary.Wpf.Services">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackground}">
        <Border Background="{DynamicResource CardBackground}"
                CornerRadius="16"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="400">
            <StackPanel>
                <TextBlock Text="{Binding [RegisterTitle], Source={x:Static services:TranslationSource.Instance}}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Username -->
                <TextBlock Text="{Binding [Username], Source={x:Static services:TranslationSource.Instance}}"
                           Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource StyledTextBox}" Margin="0,0,0,0"/>
                <TextBlock Text="{Binding UsernameError, Mode=OneWay}"
                           Style="{StaticResource ErrorText}" Margin="0,0,0,8"/>

                <!-- Email -->
                <TextBlock Text="{Binding [Email], Source={x:Static services:TranslationSource.Instance}}"
                           Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource StyledTextBox}" Margin="0,0,0,0"/>
                <TextBlock Text="{Binding EmailError, Mode=OneWay}"
                           Style="{StaticResource ErrorText}" Margin="0,0,0,8"/>

                <!-- Password -->
                <TextBlock Text="{Binding [Password], Source={x:Static services:TranslationSource.Instance}}"
                           Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource StyledPasswordBox}"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                    <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource StyledTextBox}"
                             Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Grid.Column="1" Content="&#x1F441;"
                            Background="Transparent" BorderThickness="0"
                            FontSize="18" Cursor="Hand" Margin="4,0,0,0"
                            Click="TogglePassword_Click"/>
                </Grid>
                <TextBlock Text="{Binding PasswordError, Mode=OneWay}"
                           Style="{StaticResource ErrorText}" Margin="0,0,0,8"/>

                <!-- Confirm Password -->
                <TextBlock Text="{Binding [ConfirmPassword], Source={x:Static services:TranslationSource.Instance}}"
                           Foreground="{DynamicResource PrimaryText}" FontSize="14" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Style="{StaticResource StyledPasswordBox}"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                             Margin="0,0,0,0"/>
                <TextBlock Text="{Binding ConfirmPasswordError, Mode=OneWay}"
                           Style="{StaticResource ErrorText}" Margin="0,0,0,16"/>

                <!-- Error / Success -->
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Style="{StaticResource ErrorText}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding SuccessMessage, Mode=OneWay}"
                           Foreground="{DynamicResource SuccessBrush}" FontSize="14"
                           Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibility}}"
                           Margin="0,0,0,8"/>

                <!-- Register Button -->
                <Button Content="{Binding [Register], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding RegisterCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,8,0,16"
                        FontSize="16"/>

                <Button Content="{Binding [BackToLogin], Source={x:Static services:TranslationSource.Instance}}"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Center"
                        FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
